    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib as plt\n",
    "\n",
    "from palmerpenguins import load_penguins\n",
    "df = load_penguins()\n",
    "print(df.head())\n",
    "mass_avg = df.groupby(\"sex\")[\"body_mass_g\"].mean() #filters out sex and then corresponding mass\n",
    "print(mass_avg)\n",
    "mass_avg.plot(kind='bar')"
   ]
